# ─── Sécurité ───────────────────────────────────────────────
# OBLIGATOIRE — générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_random_64_char_hex

# ─── PostgreSQL (partagé par Docker Compose) ─────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=domus_db
DOMUS_DB_PORT=5432
LABOR_DB_PORT=5433

# ─── Redis ───────────────────────────────────────────────────
REDIS_PORT=6379

# ─── MongoDB ─────────────────────────────────────────────────
MONGO_PORT=27017

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ─── Développement local (à mettre dans le .env de chaque service) ──
# service-domus/.env
#   DATABASE_URL=postgresql://admin:password@localhost:5432/domus_db
#   GRPC_PORT=50051
#   PORT=3001

# service-labor/.env
#   DATABASE_URL=postgresql://admin:password@localhost:5433/labor_db
#   REDIS_URL=redis://localhost:6379
#   DOMUS_GRPC_URL=localhost:50051
#   PORT=3002

# service-concordia/.env
#   MONGO_URL=mongodb://localhost:27017/concordia_db
#   REDIS_URL=redis://localhost:6379
#   PORT=3003

# api-gateway/.env
#   REDIS_URL=redis://localhost:6379
#   DOMUS_URL=http://localhost:3001
#   LABOR_URL=http://localhost:3002
#   PORT=4000

# ─── Logs ────────────────────────────────────────────────────
LOG_LEVEL=info
